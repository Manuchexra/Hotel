# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT for RBAC
SECRET_KEY=your-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Test users (in production use database)
# Format: username:password:role
USERS=admin:admin123:manager,reception:rec123:receptionist,house:house123:housekeeping,rs:rs123:roomservice,mtc:mtc123:maintenance,hr:hr123:hr

# Postgres database configuration
POSTGRES_USER=hotelos
POSTGRES_PASSWORD=hotelos_pass
POSTGRES_DB=hotelos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://hotelos:hotelos_pass@postgres:5432/hotelos

# Service ports (for internal use, not mandatory)
RECEPTION_PORT=8000
HOUSEKEEPING_PORT=8000
ROOMSERVICE_PORT=8000
MAINTENANCE_PORT=8000
BILLING_PORT=8000
PANEL_PORT=8000
# pgAdmin credentials
PGADMIN_DEFAULT_EMAIL=admin@hotelos.uz
PGADMIN_DEFAULT_PASSWORD=admin123
